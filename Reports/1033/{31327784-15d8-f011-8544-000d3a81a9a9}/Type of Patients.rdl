<CustomReport><Language>1033</Language><Query><fetch version="1.0" output-format="xml-platform" mapping="logical" distinct="false"><entity name="contact"><attribute name="apollo_patienttype" alias="apollo_patienttype" /><attribute name="fullname" alias="fullname" /><attribute name="emailaddress1" alias="emailaddress1" /><attribute name="apollo_contactnumber" alias="apollo_contactnumber" /><attribute name="mobilephone" alias="mobilephone" /></entity></fetch></Query><Groupings><Grouping Field="apollo_patienttype" Sort="Ascending" Width="100" SummaryValue="Count" /></Groupings><Columns><Column ID="apollo_contactnumber0" Field="apollo_contactnumber" Width="100" /><Column ID="fullname0" Field="fullname" Width="100" /><Column ID="emailaddress10" Field="emailaddress1" Width="100" /><Column ID="mobilephone0" Field="mobilephone" Width="100" /></Columns><TableLayout Display="Normal" /><Description>Number of In-Patients and Out-Patients</Description><ReportName>Type of Patients</ReportName><DefaultFilter><ReportFilter><ReportEntity paramname="CRM_FilteredContact" donotconvert="1"><fetch version="1.0" output-format="xml-platform" mapping="logical" distinct="false"><entity name="contact"><all-attributes /><filter type="and"><condition attribute="statecode" operator="eq" value="0" /><condition attribute="createdon" operator="last-x-months" value="3" /></filter></entity></fetch></ReportEntity></ReportFilter></DefaultFilter></CustomReport>